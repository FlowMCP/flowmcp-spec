            "requiredServerParams": [],
            "hasHandlers": false,
            "sharedLists": []
        }
    ],

    "agents": [
        {
            "name": "crypto-research",
            "description": "Cross-provider crypto analysis agent combining price data, on-chain analytics, and DeFi protocol metrics",
            "manifest": "agents/crypto-research/manifest.json"
        }
    ]
}
