{
    "name": "flowmcp-spec",
    "version": "4.3.1",
    "description": "FlowMCP Specification — Deterministic Normalization Layer for AI Tool Orchestration",
    "type": "module",
    "author": "a6b8",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/FlowMCP/flowmcp-spec.git"
    },
    "bugs": {
        "url": "https://github.com/FlowMCP/flowmcp-spec/issues"
    },
    "homepage": "https://github.com/FlowMCP/flowmcp-spec#readme",
    "engines": {
        "node": ">=22"
    },
    "keywords": [
        "flowmcp",
        "mcp",
        "specification",
        "ai-tools",
        "normalization"
    ],
    "scripts": {
        "generate-refs": "node scripts/generate-refs.mjs",
        "generate-docs-payload": "node scripts/generate-docs-payload.mjs",
        "generate-bridge": "node scripts/generate-bridge.mjs",
        "generate-manifest": "node scripts/generate-manifest.mjs",
        "audit-spec-quality": "node scripts/audit-spec-quality.mjs",
        "check-bridge-inverse": "node scripts/check-bridge-inverse.mjs",
        "generate-llms-txt": "node scripts/generate-llms-txt.mjs",
        "generate-best-practices-txt": "node scripts/generate-best-practices-txt.mjs",
        "sync-stats": "node scripts/sync-stats.mjs",
        "lint:versions": "node scripts/lint-versions.mjs",
        "test:refs-regex": "node scripts/test-refs-regex.mjs",
        "build": "npm run generate-refs && npm run generate-docs-payload && npm run generate-bridge && npm run generate-manifest && npm run check-bridge-inverse && npm run generate-llms-txt && npm run generate-best-practices-txt",
        "test": "node scripts/audit-spec-quality.mjs && node scripts/check-bridge-inverse.mjs && node scripts/lint-versions.mjs"
    },
    "devDependencies": {
        "ajv": "^8.20.0"
    }
}
